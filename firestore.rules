rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidWorkflow(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.nodes is list && data.edges is list &&
             data.ownerId is string;
    }

    match /workflows/{workflowId} {
      allow read: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId) && isValidWorkflow(request.resource.data);
      allow update: if isOwner(resource.data.ownerId) && isOwner(request.resource.data.ownerId) && 
                     isValidWorkflow(request.resource.data);
      allow delete: if isOwner(resource.data.ownerId);
    }

    match /executions/{executionId} {
      allow read: if isSignedIn(); // Simplified for now, should check workflow owner
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
